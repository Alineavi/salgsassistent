<!DOCTYPE html>
<html lang="da">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Alinea AI Salgsassistent</title>
  <style>
    @font-face {
      font-family: 'Alinea';
      src: url('Alinea-Black.otf') format('opentype');
      font-weight: 900;
    }
    @font-face {
      font-family: 'Alinea';
      src: url('Alinea-Bold.otf') format('opentype');
      font-weight: 700;
    }
    @font-face {
      font-family: 'Alinea';
      src: url('Alinea-Regular.otf') format('opentype');
      font-weight: 400;
    }

    *, *::before, *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    :root {
      --blue: #2C69F6;
      --cream: #FFEFD1;
      --purple: #D9C4F5;
      --dark: #1a1a2e;
      --white: #ffffff;
    }

    body {
      font-family: 'Alinea', 'Segoe UI', Arial, sans-serif;
      background: #111;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      overflow: hidden;
    }

    .slideshow {
      position: relative;
      width: 100vw;
      height: 100vh;
      overflow: hidden;
    }

    .slide {
      position: absolute;
      inset: 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 60px 80px;
      opacity: 0;
      transform: translateX(60px);
      transition: opacity 0.55s ease, transform 0.55s ease;
      pointer-events: none;
    }
    .slide.active {
      opacity: 1;
      transform: translateX(0);
      pointer-events: all;
    }
    .slide.exit {
      opacity: 0;
      transform: translateX(-60px);
    }

    .slide-blue   { background: var(--blue); color: var(--white); }
    .slide-cream  { background: var(--cream); color: var(--dark); }
    .slide-purple { background: var(--purple); color: var(--dark); }
    .slide-white  { background: var(--white); color: var(--dark); }
    .slide-dark   { background: var(--dark); color: var(--white); }

    .logo {
      position: absolute;
      top: 32px;
      left: 48px;
      height: 36px;
      opacity: 0.9;
    }
    .logo-white { filter: brightness(0) invert(1); }
    .logo-dark  { filter: none; }

    .slide-num {
      position: absolute;
      bottom: 28px;
      right: 48px;
      font-size: 13px;
      font-weight: 400;
      opacity: 0.4;
      letter-spacing: 1px;
    }

    .tag {
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 3px;
      text-transform: uppercase;
      margin-bottom: 18px;
      opacity: 0.6;
    }
    h1 {
      font-size: clamp(2.4rem, 5vw, 4rem);
      font-weight: 900;
      line-height: 1.08;
      margin-bottom: 24px;
      text-align: center;
    }
    h2 {
      font-size: clamp(1.6rem, 3.2vw, 2.6rem);
      font-weight: 900;
      line-height: 1.1;
      margin-bottom: 20px;
      text-align: center;
    }
    .subtitle {
      font-size: clamp(1rem, 2vw, 1.3rem);
      font-weight: 400;
      line-height: 1.6;
      text-align: center;
      max-width: 700px;
      opacity: 0.85;
    }

    .card-grid {
      display: grid;
      gap: 20px;
      width: 100%;
      max-width: 960px;
      margin-top: 32px;
    }
    .card-grid-2 { grid-template-columns: 1fr 1fr; }
    .card-grid-3 { grid-template-columns: 1fr 1fr 1fr; }

    .card {
      border-radius: 16px;
      padding: 28px 28px 24px;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }
    .card-blue   { background: var(--blue); color: var(--white); }
    .card-cream  { background: var(--cream); color: var(--dark); }
    .card-purple { background: var(--purple); color: var(--dark); }
    .card-white  { background: var(--white); color: var(--dark); box-shadow: 0 2px 16px rgba(0,0,0,0.07); }
    .card-dark   { background: var(--dark); color: var(--white); }

    .card-icon { font-size: 2rem; margin-bottom: 4px; }
    .card-title { font-size: 1rem; font-weight: 700; }
    .card-body  { font-size: 0.88rem; font-weight: 400; line-height: 1.55; opacity: 0.85; }

    .flow {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0;
      flex-wrap: nowrap;
      margin-top: 36px;
      width: 100%;
      max-width: 1100px;
    }
    .flow-step {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 10px;
      flex: 1;
      min-width: 0;
    }
    .flow-box {
      width: 100%;
      max-width: 150px;
      background: var(--white);
      border-radius: 14px;
      padding: 16px 10px;
      text-align: center;
      box-shadow: 0 4px 18px rgba(44,105,246,0.13);
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 6px;
    }
    .flow-box .ficon { font-size: 1.6rem; }
    .flow-box .flabel { font-size: 0.78rem; font-weight: 700; color: var(--dark); line-height: 1.3; }
    .flow-box .fsub   { font-size: 0.68rem; color: #666; line-height: 1.3; margin-top: 2px; }

    .flow-arrow {
      font-size: 1.6rem;
      color: var(--blue);
      flex-shrink: 0;
      padding: 0 4px;
      margin-bottom: 28px;
    }

    .flow-num {
      width: 26px;
      height: 26px;
      border-radius: 50%;
      background: var(--blue);
      color: #fff;
      font-size: 0.75rem;
      font-weight: 700;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .compare {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 24px;
      width: 100%;
      max-width: 900px;
      margin-top: 28px;
    }
    .compare-col {
      border-radius: 16px;
      padding: 28px;
      display: flex;
      flex-direction: column;
      gap: 14px;
    }
    .compare-label {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      opacity: 0.5;
      margin-bottom: 4px;
    }
    .compare-item {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      font-size: 0.88rem;
      line-height: 1.5;
    }
    .compare-item .icon { font-size: 1rem; flex-shrink: 0; margin-top: 1px; }

    .benefits {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 18px;
      width: 100%;
      max-width: 900px;
      margin-top: 28px;
    }
    .benefit {
      background: var(--white);
      border-radius: 14px;
      padding: 22px 24px;
      display: flex;
      align-items: flex-start;
      gap: 16px;
      box-shadow: 0 2px 14px rgba(0,0,0,0.06);
    }
    .benefit-icon { font-size: 2rem; flex-shrink: 0; }
    .benefit-text h3 { font-size: 1rem; font-weight: 700; margin-bottom: 4px; color: var(--dark); }
    .benefit-text p  { font-size: 0.83rem; color: #555; line-height: 1.5; }

    .title-accent {
      width: 64px;
      height: 6px;
      background: var(--cream);
      border-radius: 99px;
      margin: 20px auto 0;
    }

    .cta-box {
      margin-top: 40px;
      background: rgba(255,255,255,0.15);
      border: 2px solid rgba(255,255,255,0.3);
      border-radius: 16px;
      padding: 24px 40px;
      text-align: center;
      max-width: 660px;
    }
    .cta-box p { font-size: 1.05rem; font-weight: 400; line-height: 1.6; }
    .cta-box strong { font-weight: 700; }

    .nav {
      position: fixed;
      bottom: 36px;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      align-items: center;
      gap: 14px;
      z-index: 100;
      background: rgba(255,255,255,0.12);
      backdrop-filter: blur(12px);
      border: 1px solid rgba(255,255,255,0.2);
      border-radius: 99px;
      padding: 10px 20px;
    }
    .nav-btn {
      background: none;
      border: none;
      cursor: pointer;
      color: #fff;
      font-size: 1.3rem;
      width: 36px;
      height: 36px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: background 0.2s;
    }
    .nav-btn:hover { background: rgba(255,255,255,0.2); }
    .nav-dots { display: flex; gap: 7px; align-items: center; }
    .dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: rgba(255,255,255,0.35);
      cursor: pointer;
      transition: background 0.2s, transform 0.2s;
    }
    .dot.active { background: #fff; transform: scale(1.3); }

    .key-hint {
      position: fixed;
      top: 22px;
      right: 36px;
      font-size: 11px;
      color: rgba(255,255,255,0.35);
      font-family: 'Alinea', Arial, sans-serif;
      letter-spacing: 0.5px;
      z-index: 100;
    }

    .progress {
      position: fixed;
      top: 0; left: 0;
      height: 4px;
      background: var(--blue);
      transition: width 0.4s ease;
      z-index: 200;
      border-radius: 0 2px 2px 0;
    }
  </style>
</head>
<body>

<div class="progress" id="progress"></div>
<div class="key-hint">← → piletaster</div>

<div class="slideshow" id="slideshow">

  <!-- SLIDE 1 — Titel -->
  <section class="slide slide-blue active" id="s1">
    <img src="alinea_logo.png" class="logo logo-white" alt="Alinea logo" />
    <div class="tag" style="color:rgba(255,255,255,0.6);">Intern præsentation · 2026</div>
    <h1>Sælg mere.<br/>Bevar kvaliteten.</h1>
    <div class="title-accent"></div>
    <p class="subtitle" style="margin-top:28px; color:rgba(255,255,255,0.85);">
      Et AI-værktøj der omdanner vores faktuelle bogtekster<br/>
      til professionelle salgstekster — i Alineas egen stemme.
    </p>
    <span class="slide-num">01 / 05</span>
  </section>

  <!-- SLIDE 2 — Hvad er assistenten? -->
  <section class="slide slide-cream" id="s2">
    <img src="alinea_logo.png" class="logo logo-dark" alt="Alinea logo" />
    <div class="tag">Hvad er assistenten?</div>
    <h2>En AI-redaktør der kender<br/>Alineas stemme</h2>
    <div class="card-grid card-grid-3" style="margin-top:36px;">
      <div class="card card-blue">
        <div class="card-icon">📥</div>
        <div class="card-title">Input</div>
        <div class="card-body">Den modtager vores eksisterende, faktuelle bogtekster — præcis som de er.</div>
      </div>
      <div class="card card-white">
        <div class="card-icon">🤖</div>
        <div class="card-title">Transformation</div>
        <div class="card-body">Den omskriver teksten til en engagerende salgstekst i Alineas tone — uden at opfinde noget nyt.</div>
      </div>
      <div class="card card-purple">
        <div class="card-icon">✅</div>
        <div class="card-title">Output</div>
        <div class="card-body">2 versioner + en forklaring på præcis hvad der er ændret og hvorfor det sælger bedre.</div>
      </div>
    </div>
    <p class="subtitle" style="margin-top:28px; font-size:0.95rem;">
      Målrettet <strong>lærere, skolebibliotekarer og pædagogiske konsulenter</strong> — dem der vælger og køber.
    </p>
    <span class="slide-num">02 / 05</span>
  </section>

  <!-- SLIDE 3 — Flow -->
  <section class="slide slide-white" id="s3">
    <img src="alinea_logo.png" class="logo logo-dark" alt="Alinea logo" />
    <div class="tag" style="color:var(--blue);">Sådan fungerer den</div>
    <h2>Fra tekst til salgstekst<br/>i 6 trin</h2>
    <div class="flow">
      <div class="flow-step">
        <div class="flow-num">1</div>
        <div class="flow-box">
          <div class="ficon">📄</div>
          <div class="flabel">Bogtekst indsendes</div>
          <div class="fsub">Redaktøren indsætter den originale beskrivelse</div>
        </div>
      </div>
      <div class="flow-arrow">→</div>
      <div class="flow-step">
        <div class="flow-num">2</div>
        <div class="flow-box">
          <div class="ficon">❓</div>
          <div class="flabel">5 hurtige spørgsmål</div>
          <div class="fsub">Format, pris, varighed, tidsbesparelse, niveau</div>
        </div>
      </div>
      <div class="flow-arrow">→</div>
      <div class="flow-step">
        <div class="flow-num">3</div>
        <div class="flow-box">
          <div class="ficon">✍️</div>
          <div class="flabel">Redaktør svarer</div>
          <div class="fsub">Under 2 minutter</div>
        </div>
      </div>
      <div class="flow-arrow">→</div>
      <div class="flow-step">
        <div class="flow-num">4</div>
        <div class="flow-box">
          <div class="ficon">🤖</div>
          <div class="flabel">AI skriver</div>
          <div class="fsub">2 salgstekster i Alineas tone</div>
        </div>
      </div>
      <div class="flow-arrow">→</div>
      <div class="flow-step">
        <div class="flow-num">5</div>
        <div class="flow-box">
          <div class="ficon">💡</div>
          <div class="flabel">Forklaring</div>
          <div class="fsub">Hvad er ændret og hvorfor?</div>
        </div>
      </div>
      <div class="flow-arrow">→</div>
      <div class="flow-step">
        <div class="flow-num">6</div>
        <div class="flow-box" style="background:var(--blue);">
          <div class="ficon">🛒</div>
          <div class="flabel" style="color:#fff;">Klar til webshop</div>
          <div class="fsub" style="color:rgba(255,255,255,0.75);">Redaktøren vælger den bedste version</div>
        </div>
      </div>
    </div>
    <span class="slide-num">03 / 05</span>
  </section>

  <!-- SLIDE 4 — Hvad ændres? (OPDATERET) -->
  <section class="slide slide-purple" id="s4">
    <img src="alinea_logo.png" class="logo logo-dark" alt="Alinea logo" />
    <div class="tag">Hvad ændres?</div>
    <h2>Samme fakta. Stærkere budskab.</h2>
    <div class="compare">
      <div class="compare-col" style="background:rgba(255,255,255,0.45);">
        <div class="compare-label">❌ Før — beskrivende</div>
        <div class="compare-item"><span class="icon">📋</span><span><strong>Tør overskrift</strong><br/>"En innovativ matematikbog til regnestrategitræning"</span></div>
        <div class="compare-item"><span class="icon">📋</span><span><strong>Taler om bogen, ikke til læreren</strong><br/>Teksten informerer — men engagerer ikke</span></div>
        <div class="compare-item"><span class="icon">📋</span><span><strong>Funktioner i fokus</strong><br/>"Bogen har 17 kapitler..."</span></div>
        <div class="compare-item"><span class="icon">📋</span><span><strong>Ingen begrundelse for købet</strong><br/>Hvad får skolen egentlig for pengene?</span></div>
      </div>
      <div class="compare-col" style="background:var(--blue);">
        <div class="compare-label" style="color:rgba(255,255,255,0.6);">✅ Efter — sælgende</div>
        <div class="compare-item" style="color:#fff;"><span class="icon">🚀</span><span><strong>Fængende overskrift</strong><br/>Dine elever er allerede nysgerrige. <em>Dyrenes butik</em> giver nysgerrigheden et matematisk sprog.</span></div>
        <div class="compare-item" style="color:#fff;"><span class="icon">🎯</span><span><strong>Direkte tiltale</strong><br/>"Du og dine elever..." — personligt og relevant</span></div>
        <div class="compare-item" style="color:#fff;"><span class="icon">💡</span><span><strong>Fordele i fokus</strong><br/>"17 lektioner — klar til brug med det samme"</span></div>
        <div class="compare-item" style="color:#fff;"><span class="icon">💰</span><span><strong>Prisen taler for sig selv</strong><br/>Tidsbesparelse + kvalitet + fordele synliggjort direkte i teksten</span></div>
      </div>
    </div>
    <p style="font-size:0.82rem; margin-top:18px; opacity:0.6; font-style:italic;">Fakta, fagbegreber og klassetrin forbliver 100% uændrede.</p>
    <span class="slide-num">04 / 05</span>
  </section>

  <!-- SLIDE 5 — Fordele -->
  <section class="slide slide-dark" id="s5">
    <img src="alinea_logo.png" class="logo logo-white" alt="Alinea logo" />
    <div class="tag" style="color:rgba(255,255,255,0.45);">Hvad vinder Alinea?</div>
    <h2 style="color:#fff;">Sælg mere.<br/>Ingen kompromiser.</h2>
    <div class="benefits" style="margin-top:30px;">
      <div class="benefit">
        <div class="benefit-icon">⚡</div>
        <div class="benefit-text">
          <h3>Hurtigere produktion</h3>
          <p>Redaktøren starter ikke fra bunden. Slagkraftig tekst på få minutter.</p>
        </div>
      </div>
      <div class="benefit">
        <div class="benefit-icon">🎯</div>
        <div class="benefit-text">
          <h3>Konsistent Alinea-tone</h3>
          <p>Altid samme stemme — uanset hvem i teamet der bruger assistenten.</p>
        </div>
      </div>
      <div class="benefit">
        <div class="benefit-icon">💪</div>
        <div class="benefit-text">
          <h3>Stærkere salgsargumenter</h3>
          <p>Teksterne forsvarer prisen og fremhæver konkret værdi for køberen.</p>
        </div>
      </div>
      <div class="benefit">
        <div class="benefit-icon">🔒</div>
        <div class="benefit-text">
          <h3>Nul faktafejl</h3>
          <p>Assistenten opfinder aldrig noget. Fakta er hellige — altid.</p>
        </div>
      </div>
    </div>
    <div class="cta-box">
      <p>Et værktøj der hjælper os med at <strong>sælge mere</strong> —<br/>uden at gå på kompromis med teksternes niveau og troværdighed.</p>
    </div>
    <span class="slide-num" style="color:rgba(255,255,255,0.35);">05 / 05</span>
  </section>

</div>

<nav class="nav">
  <button class="nav-btn" id="prevBtn">&#8592;</button>
  <div class="nav-dots" id="dots"></div>
  <button class="nav-btn" id="nextBtn">&#8594;</button>
</nav>

<script>
  const slides   = Array.from(document.querySelectorAll('.slide'));
  const dotsWrap = document.getElementById('dots');
  const progress = document.getElementById('progress');
  let current    = 0;

  slides.forEach((_, i) => {
    const d = document.createElement('span');
    d.className = 'dot' + (i === 0 ? ' active' : '');
    d.addEventListener('click', () => goTo(i));
    dotsWrap.appendChild(d);
  });

  function goTo(n) {
    if (n === current) return;
    slides[current].classList.remove('active');
    slides[current].classList.add('exit');
    const prev = current;
    current = (n + slides.length) % slides.length;
    setTimeout(() => slides[prev].classList.remove('exit'), 560);
    slides[current].classList.add('active');
    document.querySelectorAll('.dot').forEach((d, i) => d.classList.toggle('active', i === current));
    progress.style.width = ((current + 1) / slides.length * 100) + '%';
  }

  document.getElementById('nextBtn').addEventListener('click', () => goTo(current + 1));
  document.getElementById('prevBtn').addEventListener('click', () => goTo(current - 1));

  document.addEventListener('keydown', e => {
    if (e.key === 'ArrowRight' || e.key === 'ArrowDown') goTo(current + 1);
    if (e.key === 'ArrowLeft'  || e.key === 'ArrowUp')   goTo(current - 1);
  });

  progress.style.width = (1 / slides.length * 100) + '%';
</script>

</body>
</html>
